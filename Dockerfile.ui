# syntax=docker/dockerfile:1
#
# Streamlit dashboard image.
#
# The UI holds no model — it is a pure client of the API — so this image skips
# TensorFlow entirely and stays around 400 MB rather than 1.5 GB.

FROM python:3.10-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PORT=8501 \
    API_URL=http://api:8000

WORKDIR /app

COPY requirements.txt .

# Only the client-side stack. TensorFlow, FastAPI and locust are deliberately
# absent; installing them here would triple the image for no benefit.
RUN grep -iE "^(streamlit|plotly|pandas|numpy|requests|Pillow)" requirements.txt > ui-requirements.txt \
    && pip install --no-cache-dir -r ui-requirements.txt

RUN useradd --create-home --uid 1000 appuser

COPY --chown=appuser:appuser ui/ ./ui/

USER appuser

EXPOSE 8501

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD python -c "import urllib.request,os; urllib.request.urlopen(f'http://localhost:{os.getenv(\"PORT\",8501)}/_stcore/health').read()" || exit 1

CMD streamlit run ui/app.py \
    --server.port=${PORT} \
    --server.address=0.0.0.0 \
    --server.headless=true \
    --browser.gatherUsageStats=false
